# ============================================================
# HIRRD — ENVIRONMENT VARIABLES
# Copy this file to .env.local for local development
# Add all values to Vercel environment variables for production
# ============================================================

# ── SUPABASE (required) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Settings → API → service_role — NEVER expose publicly

# ── ANTHROPIC (required — CV parsing) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# ── RESEND (required — email notifications) ────────────────
RESEND_API_KEY=re_xxx              # resend.com → API Keys → Create
ADMIN_EMAIL=admin@hirrd.com        # Email to receive employer/institution lead alerts

# ── TWILIO (required — SMS + WhatsApp) ────────────────────
TWILIO_ACCOUNT_SID=ACxxx           # twilio.com → Console → Account SID
TWILIO_AUTH_TOKEN=xxx              # twilio.com → Console → Auth Token
TWILIO_SMS_FROM=+27XXXXXXXXX       # SA number purchased from Twilio
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Sandbox: +14155238886 | Production: your WhatsApp number

# ── CLICKATELL (optional — SMS fallback, best SA coverage) ─
CLICKATELL_API_KEY=xxx             # clickatell.com → API Access

# ── UPSTASH REDIS (required — rate limiting) ───────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx       # upstash.com → Redis database → REST API

# ── SENTRY (required — error monitoring) ───────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456

# ── FEATURE FLAGS ──────────────────────────────────────────
NEXT_PUBLIC_PHOTO_ENABLED=false    # ⚠️ Keep false until POPIA s.26 consent reviewed by SA attorney
NEXT_PUBLIC_APP_URL=https://hirrd-web.vercel.app

# ── SECURITY ───────────────────────────────────────────────
OTP_SALT=change-this-to-a-random-string-min-32-chars
CRON_SECRET=change-this-to-a-random-string-for-cron-auth
